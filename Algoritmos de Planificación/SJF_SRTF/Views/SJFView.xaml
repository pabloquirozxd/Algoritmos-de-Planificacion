<UserControl x:Class="Algoritmos_de_Planificación.SJF_SRTF.Views.SJFView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1000">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ENCABEZADO -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Simulador SJF - Servidor de Impresión"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorPrimario}"/>

                <TextBlock Text="Shortest Job First: Los trabajos más cortos se imprimen primero. No expropiativo."
                           FontSize="15"
                           Foreground="{StaticResource TextoClaro}"
                           Margin="0,8,0,0"/>

                <TextBlock Text="Proceso = Trabajo | Burst Time = Tiempo de impresión | Waiting Time = Tiempo en cola | Turnaround Time = Tiempo total"
                           FontSize="13"
                           Foreground="{StaticResource TextoClaro}"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- FORMULARIO -->
            <Grid Grid.Row="1" Margin="0,0,0,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Registrar trabajo"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextoOscuro}"
                           Margin="0,0,0,14"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Nombre del Proceso"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextoOscuro}"/>
                        <TextBox x:Name="txtNombre" Height="38" Margin="0,6,0,0" Padding="8"
                                 Background="{StaticResource InputColor}" BorderBrush="{StaticResource BordesSuaves}"
                                 ToolTip="Ej: P1, P2, P3"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="12,0,12,0">
                        <TextBlock Text="Tiempo de Llegada (min)"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextoOscuro}"/>
                        <TextBox x:Name="txtLlegada" Height="38" Margin="0,6,0,0" Padding="8"
                                 Background="{StaticResource InputColor}" BorderBrush="{StaticResource BordesSuaves}"
                                 ToolTip="Tiempo en que llega el trabajo (mínimo 0)"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="12,0,0,0">
                        <TextBlock Text="Ráfaga CPU (min)"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextoOscuro}"/>
                        <TextBox x:Name="txtRafaga" Height="38" Margin="0,6,0,0" Padding="8"
                                 Background="{StaticResource InputColor}" BorderBrush="{StaticResource BordesSuaves}"
                                 ToolTip="Tiempo de impresión en minutos (mayor a 0)"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnAgregar" Grid.Column="0" Content="Agregar trabajo" Height="40" Margin="0,0,8,0"
                            Style="{StaticResource MenuButtonStyle}" Click="btnAgregar_Click"/>

                    <Button x:Name="btnSimular" Grid.Column="1" Content="Ejecutar SJF" Height="40" Margin="8,0,8,0"
                            Style="{StaticResource MenuButtonStyle}" Click="btnSimular_Click"/>

                    <Button x:Name="btnEjemplo" Grid.Column="2" Content="Cargar ejemplo" Height="40" Margin="8,0,8,0"
                            Style="{StaticResource MenuButtonStyle}" Click="btnEjemplo_Click"/>

                    <Button x:Name="btnLimpiar" Grid.Column="3" Content="Limpiar" Height="40" Margin="8,0,0,0"
                            Style="{StaticResource MenuButtonStyle}" Click="btnLimpiar_Click"/>
                </Grid>
            </Grid>

            <!-- TABLA DE PROCESOS -->
            <Grid Grid.Row="2" Margin="0,0,0,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Procesos en cola" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextoOscuro}" Margin="0,0,0,12"/>

                <DataGrid x:Name="dgProcesos" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"
                          HeadersVisibility="Column" Background="White" BorderBrush="{StaticResource BordesSuaves}"
                          GridLinesVisibility="Horizontal" RowHeight="38" FontSize="13"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <!-- TABLA DE RESULTADOS -->
            <Grid Grid.Row="3" Margin="0,0,0,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Resultados de la simulación" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextoOscuro}" Margin="0,0,0,12"/>

                <DataGrid x:Name="dgResultados" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"
                          HeadersVisibility="Column" Background="White" BorderBrush="{StaticResource BordesSuaves}"
                          GridLinesVisibility="Horizontal" RowHeight="38" FontSize="13"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <!-- RESULTADOS -->
            <Grid Grid.Row="4" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Promedio Turnaround Time" FontWeight="Bold" Foreground="{StaticResource ColorPrimario}"/>
                    <TextBlock x:Name="txtPromRetorno" Text="0" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextoOscuro}" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="20,0,20,0">
                    <TextBlock Text="Promedio Waiting Time" FontWeight="Bold" Foreground="{StaticResource ColorPrimario}"/>
                    <TextBlock x:Name="txtPromEspera" Text="0" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextoOscuro}" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="20,0,0,0">
                    <TextBlock Text="Proceso actual" FontWeight="Bold" Foreground="{StaticResource ColorPrimario}"/>
                    <TextBlock x:Name="txtProcesoActual" Text="Ninguno" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextoOscuro}" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <!-- DIAGRAMA DE GANTT -->
            <StackPanel Grid.Row="5" Margin="0,0,0,20">
                <TextBlock Text="Diagrama de Gantt" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextoOscuro}" Margin="0,0,0,10"/>

                <ScrollViewer x:Name="scrollGantt" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="spGantt" Orientation="Horizontal" MinHeight="80"/>
                </ScrollViewer>

                
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>