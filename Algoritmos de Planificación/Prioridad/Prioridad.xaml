<UserControl x:Class="Algoritmos_de_Planificación.Prioridad.Prioridad"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Algoritmos_de_Planificación.Prioridad"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ENCABEZADO -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="Simulador de Prioridad - Soporte Técnico"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource ColorPrimario}"/>

                <TextBlock Text="Los tickets se atienden según su nivel de urgencia."
                           FontSize="15"
                           Foreground="{StaticResource TextoClaro}"
                           Margin="0,8,0,0"/>

                <TextBlock Text="Prioridad 1 = Crítica | Prioridad 2 = Media | Prioridad 3 = Baja"
                           FontSize="13"
                           Foreground="{StaticResource TextoClaro}"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- FORMULARIO -->
            <Grid Grid.Row="1" Margin="0,0,0,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Registrar ticket"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextoOscuro}"
                           Margin="0,0,0,14"/>

                <!-- CAMPOS -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Ticket / Problema"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextoOscuro}"/>

                        <TextBox x:Name="txtTicket"
                                 Height="38"
                                 Margin="0,6,0,0"
                                 Padding="8"
                                 Background="{StaticResource InputColor}"
                                 BorderBrush="{StaticResource BordesSuaves}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="12,0,12,0">
                        <TextBlock Text="Arrival Time"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextoOscuro}"/>

                        <TextBox x:Name="txtArrivalTime"
                                 Height="38"
                                 Margin="0,6,0,0"
                                 Padding="8"
                                 Background="{StaticResource InputColor}"
                                 BorderBrush="{StaticResource BordesSuaves}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="12,0,12,0">
                        <TextBlock Text="Burst Time"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextoOscuro}"/>

                        <TextBox x:Name="txtBurstTime"
                                 Height="38"
                                 Margin="0,6,0,0"
                                 Padding="8"
                                 Background="{StaticResource InputColor}"
                                 BorderBrush="{StaticResource BordesSuaves}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="12,0,0,0">
                        <TextBlock Text="Prioridad"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextoOscuro}"/>

                        <ComboBox x:Name="cmbPrioridad"
                                  Height="38"
                                  Margin="0,6,0,0"
                                  Padding="6"
                                  Background="{StaticResource InputColor}"
                                  BorderBrush="{StaticResource BordesSuaves}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="1 - Crítica"/>
                            <ComboBoxItem Content="2 - Media"/>
                            <ComboBoxItem Content="3 - Baja"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- TIPO DE ALGORITMO -->
                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tipo de prioridad"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextoOscuro}"/>

                        <ComboBox x:Name="cmbTipoPrioridad"
                                  Height="38"
                                  Margin="0,6,0,0"
                                  Padding="6"
                                  Background="{StaticResource InputColor}"
                                  BorderBrush="{StaticResource BordesSuaves}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="No expropiativa"/>
                            <ComboBoxItem Content="Expropiativa"/>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="No expropiativa: el ticket actual no se interrumpe. Expropiativa: un ticket crítico puede pausar a uno menos urgente."
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource TextoClaro}"
                               Margin="25,25,0,0"/>
                </Grid>

                <!-- BOTONES -->
                <Grid Grid.Row="3" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnAgregar"
                            Grid.Column="0"
                            Content="Agregar ticket"
                            Height="40"
                            Click="btnAgregar_Click"
                            Margin="0,0,8,0"
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button x:Name="btnEjecutar"
                            Grid.Column="1"
                            Content="Ejecutar algoritmo"
                            Height="40"
                            Margin="8,0,8,0"
                            Click="btnEjecutar_Click"
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button x:Name="btnEjemplo"
                            Grid.Column="2"
                            Content="Cargar ejemplo"
                            Height="40"
                            Margin="8,0,8,0"
                            Click="btnEjemplo_Click"
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button x:Name="btnLimpiar"
                            Grid.Column="3"
                            Content="Limpiar"
                            Click="btnLimpiar_Click"
                            Height="40"
                            Margin="8,0,0,0"
                            Style="{StaticResource MenuButtonStyle}"/>
                </Grid>
            </Grid>

            <!-- TABLA -->
            <Grid Grid.Row="2" Margin="0,0,0,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="360"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Cola de tickets"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextoOscuro}"
                           Margin="0,0,0,12"/>

                <DataGrid x:Name="dgTickets"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          Background="White"
                          BorderBrush="{StaticResource BordesSuaves}"
                          GridLinesVisibility="Horizontal"
                          RowHeight="38"
                          FontSize="13"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Proceso"
                                            Binding="{Binding Proceso}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Ticket"
                                            Binding="{Binding Ticket}"
                                            Width="180"/>

                        <DataGridTextColumn Header="Arrival"
                                            Binding="{Binding ArrivalTime}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Burst"
                                            Binding="{Binding BurstTime}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Prioridad"
                                            Binding="{Binding Prioridad}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Restante"
                                            Binding="{Binding RemainingTime}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Completion"
                                            Binding="{Binding CompletionTime}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Waiting"
                                            Binding="{Binding WaitingTime}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Turnaround"
                                            Binding="{Binding TurnaroundTime}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Estado"
                                            Binding="{Binding Estado}"
                                            Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- RESULTADOS -->
            <Grid Grid.Row="3" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <TextBlock Text="Promedio Waiting Time"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorPrimario}"/>
                    <TextBlock x:Name="txtPromedioEspera"
                               Text="0"
                               FontSize="22"
                               FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,18,0">
                    <TextBlock Text="Promedio Turnaround Time"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorPrimario}"/>
                    <TextBlock x:Name="txtPromedioRetorno"
                               Text="0"
                               FontSize="22"
                               FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="18,0,18,0">
                    <TextBlock Text="Ticket actual"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorPrimario}"/>
                    <TextBlock x:Name="txtTicketActual"
                               Text="Ninguno"
                               FontSize="22"
                               FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="18,0,0,0">
                    <TextBlock Text="Modo"
                               FontWeight="Bold"
                               Foreground="{StaticResource ColorPrimario}"/>
                    <TextBlock x:Name="txtModo"
                               Text="No expropiativa"
                               FontSize="22"
                               FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- DIAGRAMA -->
            <StackPanel Grid.Row="4" Margin="0,0,0,20">
                <TextBlock Text="Diagrama de ejecución"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextoOscuro}"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Muestra el orden de atención de los tickets. En modo expropiativo, un mismo ticket puede aparecer más de una vez."
                           FontSize="13"
                           Foreground="{StaticResource TextoClaro}"
                           Margin="0,0,0,10"/>

                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="spGantt"
                                Orientation="Horizontal"
                                MinHeight="80"/>
                </ScrollViewer>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>
